{
  "title": "Texas Family Code §153.312/153.317 - Standard Possession Order",
  "jurisdiction": "Texas",
  "rules": {
    "espo": {
      "description": "Extended Standard Possession Order (ESPO)",
      "weekdays": {
        "dad": ["Thursday"],
        "mom": ["Monday", "Tuesday", "Wednesday", "Friday"]
      },
      "weekends": {
        "pattern": "1st_3rd_5th_friday",
        "parent": "dad",
        "note": "1st, 3rd, 5th Friday of each month, school dismissal to Monday school return (<50 miles)"
      },
      "thursday": {
        "parent": "dad",
        "note": "School dismissal Thursday to school return Friday"
      },
      "holidays": {
        "thanksgiving": {
          "description": "Odd year: Dad Thu 6pm-Sun 6pm; Even year: Mom Thu 6pm-Sun 6pm",
          "odd_year": "dad",
          "even_year": "mom"
        },
        "christmas": {
          "description": "Odd year: Dad first half; Even year: Mom first half",
          "split_day": 28,
          "odd_year": "dad_first",
          "even_year": "mom_first"
        },
        "spring_break": {
          "odd_year": "mom",
          "even_year": "dad"
        },
        "summer": {
          "dad_days": 30,
          "dad_start_month": 7,
          "dad_start_day": 1,
          "dad_end_month": 7,
          "dad_end_day": 30,
          "description": "Dad gets July 1-30"
        },
        "fathers_day": "dad",
        "mothers_day": "mom"
      },
      "noschool_days": {
        "description": "Alternating by odd/even calendar year",
        "odd_year": "dad",
        "even_year": "mom"
      }
    },
    "spo": {
      "description": "Standard Possession Order (SPO)",
      "weekdays": {
        "dad": [],
        "mom": ["Monday", "Tuesday", "Wednesday", "Thursday", "Friday"]
      },
      "weekends": {
        "pattern": "1st_3rd_5th_friday",
        "parent": "dad",
        "note": "Same 1st/3rd/5th Friday pattern as ESPO, but no Thursday overnight"
      },
      "thursday": {
        "parent": "dad",
        "note": "SPO: limited or no Thursday possession per agreement"
      },
      "holidays": {
        "thanksgiving": {
          "description": "Same alternating pattern as ESPO",
          "odd_year": "dad",
          "even_year": "mom"
        },
        "christmas": {
          "description": "Same split as ESPO",
          "split_day": 28,
          "odd_year": "dad_first",
          "even_year": "mom_first"
        },
        "spring_break": {
          "odd_year": "mom",
          "even_year": "dad"
        },
        "summer": {
          "dad_days": 30,
          "dad_start_month": 7,
          "dad_start_day": 1,
          "dad_end_month": 7,
          "dad_end_day": 30,
          "description": "Dad gets July 1-30"
        },
        "fathers_day": "dad",
        "mothers_day": "mom"
      },
      "noschool_days": {
        "description": "Alternating by odd/even calendar year",
        "odd_year": "dad",
        "even_year": "mom"
      }
    }
  },
  "fallback": "espo"
}
